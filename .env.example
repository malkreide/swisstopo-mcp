# Example environment configuration for swisstopo-mcp.
# Copy to `.env` (git-ignored) and adjust. None of these are secrets — the
# server uses only key-less public APIs — but the file documents the knobs.

# Comma-separated cantonal OEREB endpoints to enable (e.g. "ZH,BE").
SWISSTOPO_OEREB_CANTONS=ZH

# HTTP transport (only used with `--http`). Bind 127.0.0.1 locally; a container
# sets 0.0.0.0 itself. Never commit a real 0.0.0.0 default in code (SEC-016).
SWISSTOPO_HTTP_HOST=127.0.0.1
SWISSTOPO_HTTP_PORT=8000

# Comma-separated CORS origins for browser MCP clients (no wildcard).
SWISSTOPO_ALLOWED_ORIGINS=

# Log level: DEBUG | INFO | WARNING | ERROR
SWISSTOPO_LOG_LEVEL=INFO
